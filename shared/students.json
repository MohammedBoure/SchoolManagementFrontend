                        ],
                        "format": "int32"
                    },
                    "policy_id": {
                        "type": [
                            "integer",
                            "null"
                        ],
                        "format": "int32"
                    },
                    "registration_date": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date"
                    },
                    "status": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "user_id": {
                        "type": [
                            "integer",
                            "null"
                        ],
                        "format": "int32"
                    }
                }
            },
            "AxumInsertStudents": {
                "type": "object",
                "properties": {
                    "blood_group": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "class_id": {
                        "type": [
                            "integer",
                            "null"
                        ],
                        "format": "int32"
                    },
                    "date_of_birth": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date"
                    },
                    "medical_info": {
                        "type": [
                            "string",
