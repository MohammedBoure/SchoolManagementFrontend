                        ],
                        "format": "date"
                    },
                    "id": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "medical_info": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "parent_id": {
                        "type": [
                            "integer",
