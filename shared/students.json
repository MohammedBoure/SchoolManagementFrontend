                                "$ref": "#/components/schemas/Status"
                            }
                        ]
                    },
                    "user_id": {
                        "type": [
                            "integer",
                            "null"
                        ],
                        "format": "int32"
                    }
                }
            },
            "Status": {
                "type": "string",
