{
    "openapi": "3.1.0",
    "info": {
        "title": "Teachers API Docs",
        "description": "Strict API specification for the 'teachers' table. Use this to generate frontend services, API calls, and UI components.",
        "version": "0.2.0"
    },
    "servers": [
        {
            "url": "http://qylad.duckdns.org:2000",
